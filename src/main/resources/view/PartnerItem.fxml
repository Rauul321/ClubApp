<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER_LEFT" prefHeight="85.0" prefWidth="850.0" spacing="15.0" styleClass="form-container" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="CENTER" minWidth="55.0" prefWidth="55.0" style="-fx-background-color: #457B9D; -fx-background-radius: 50;">
            <children>
                <Label fx:id="lblInitial" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 18px;" text="👤" />
            </children>
            <HBox.margin>
                <Insets left="10.0" />
            </HBox.margin>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="3.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox spacing="5.0">
                    <children>
                        <Label fx:id="partnerName" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: white;" text="Name" />
                        <Label fx:id="partnerSurname" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: white;" text="Surname" />
                    </children>
                </HBox>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="partnerEmail" style="-fx-text-fill: #A8DADC; -fx-font-size: 13px;" text="email@domain.com" />
                        <Label style="-fx-text-fill: #95a5a6;" text="•" />
                        <Label fx:id="role" style="-fx-text-fill: #f1c40f; -fx-font-weight: bold; -fx-font-size: 11px; -fx-background-color: rgba(241, 196, 15, 0.1); -fx-padding: 2 6 2 6; -fx-background-radius: 4;" text="PARTNER" />
                    </children>
                </HBox>
            </children>
            <HBox.margin>
                <Insets left="10.0" />
            </HBox.margin>
        </VBox>

        <Pane HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="12.0">
            <children>
                <Button onAction="#handleModify" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Modify"
                        style="-fx-background-color: #A8DADC; -fx-text-fill: #1D3557; -fx-background-radius: 10; -fx-font-weight: bold;" />

                <Button onAction="#handleDelete" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Delete"
                        style="-fx-background-color: #E63946; -fx-background-radius: 10; -fx-font-weight: bold;" />
            </children>
            <padding>
                <Insets right="15.0" />
            </padding>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</HBox>
