<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.Separator?>
<HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="850.0" spacing="15.0" styleClass="form-container" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" minWidth="60.0" prefWidth="60.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 12;">
         <children>
            <Label style="-fx-font-size: 24px;" text="⚙️" />
         </children>
         <HBox.margin>
            <Insets left="10.0" />
         </HBox.margin>
      </VBox>

      <VBox alignment="CENTER_LEFT" spacing="3.0" HBox.hgrow="ALWAYS">
         <children>
            <Label fx:id="activityName" style="-fx-font-weight: bold; -fx-font-size: 17px; -fx-text-fill: white;" text="Tournament Finals">
               <font>
                  <Font name="System Bold" size="17.0" />
               </font>
            </Label>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="typeLabel" style="-fx-text-fill: #38B000; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: rgba(56, 176, 0, 0.1); -fx-padding: 2 8 2 8; -fx-background-radius: 5;" text="COMPETITION" />
                  <Label style="-fx-text-fill: #95a5a6;" text="•" />
                  <Label fx:id="date" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;" text="Jan 15, 2026" />
               </children>
            </HBox>
         </children>
         <HBox.margin>
            <Insets left="10.0" />
         </HBox.margin>
      </VBox>

      <Pane HBox.hgrow="ALWAYS" />

      <HBox alignment="CENTER" spacing="8.0">
         <children>
            <Button fx:id="handleParticipants" onAction="#handleParticipants" prefHeight="35.0" styleClass="secondary-button" text="👥" style="-fx-font-size: 14px; -fx-background-radius: 10;"/>

            <Separator orientation="VERTICAL" prefHeight="30.0" opacity="0.2" />

            <Button fx:id="joinButton" onAction="#handleJoinActivity" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Join"
                    style="-fx-background-color: #38B000; -fx-background-radius: 8;" />

            <Button fx:id="unjoinButton" onAction="#handleUnjoinActivity" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Unroll"
                    style="-fx-background-color: #e67e22; -fx-background-radius: 8;" />

            <Separator orientation="VERTICAL" prefHeight="30.0" opacity="0.2" />

            <Button onAction="#handleModifyActivity" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Modify"
                    style="-fx-background-color: #A8DADC;; -fx-text-fill: #2c3e50; -fx-background-radius: 8; -fx-font-weight: bold;" />

            <Button onAction="#handleDeleteActivity" prefHeight="38.0" prefWidth="120.0" styleClass="primary-button" text="Delete"
                    style="-fx-background-color: #c0392b; -fx-background-radius: 8; -fx-font-weight: bold;" />
         </children>
         <padding>
            <Insets right="15.0" />
         </padding>
      </HBox>
   </children>
   <padding>
      <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
   </padding>
</HBox>
