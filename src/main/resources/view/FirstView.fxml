<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="mainStackPane" prefHeight="720.0" prefWidth="1080.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ImageView fx:id="backgroundImageView" pickOnBounds="true" preserveRatio="false"
                   fitHeight="${mainStackPane.height}" fitWidth="${mainStackPane.width}">
            <image>
                <Image url="@../images/background.PNG" />
            </image>
        </ImageView>

        <Rectangle fill="#00000088" height="${mainStackPane.height}" width="${mainStackPane.width}" />

        <VBox alignment="CENTER" spacing="40.0">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: #38b000; -fx-font-weight: bold; -fx-letter-spacing: 5;" text="MANAGEMENT">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label styleClass="welcome-title" text="CLUB APP" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="110.0" />
                            </font>
                        </Label>
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#38b000" height="4.0" width="120.0" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" maxWidth="400.0" spacing="25.0"
                      style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.2); -fx-border-radius: 20; -fx-backdrop-filter: blur(10px);">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <Label text="Be part of the club" textAlignment="CENTER" textFill="#bdc3c7" wrapText="true">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>

                        <VBox spacing="15.0">
                            <children>
                                <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" onAction="#handleLogin" prefHeight="50.0" styleClass="primary-button" text="Log In" />
                                <Button fx:id="signUpButton" maxWidth="1.7976931348623157E308" onAction="#handleSignUp" prefHeight="50.0" styleClass="secondary-button" text="Create Account" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</StackPane>
