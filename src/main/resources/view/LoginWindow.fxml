<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="background-pane"
            stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <VBox alignment="CENTER" maxWidth="350.0" prefWidth="350.0" spacing="10.0" styleClass="form-container">
               <children>
                  <Label styleClass="title-label" text="Inicia sesión">
                     <font>
                        <Font name="Yu Gothic Regular" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>

                  <VBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <Label styleClass="input-label" text="Enter your email:" />
                        <TextField fx:id="emailField" prefHeight="35.0" promptText="example@mail.com" />
                     </children>
                  </VBox>

                  <VBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <Label styleClass="input-label" text="Enter your password:">
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Label>
                        <PasswordField fx:id="passwordField" prefHeight="35.0" promptText="••••••••" />
                     </children>
                  </VBox>

                  <Button id="loginButton" mnemonicParsing="false" onAction="#handleLogin"
                          prefHeight="40.0" prefWidth="200.0" styleClass="primary-button" text="Enter">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Button>

                  <Label fx:id="statusLabel" styleClass="status-message" wrapText="true" />

                  <VBox alignment="CENTER" spacing="2.0">
                     <children>
                        <Hyperlink fx:id="signupLink" onAction="#handleLinkSignup"
                                   styleClass="secondary-link" text="Create an account" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
