<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="background-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox alignment="TOP_CENTER" maxWidth="450.0" prefWidth="400.0" spacing="25.0" styleClass="form-container">
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <StackPane>
                                    <children>
                                        <Circle fill="#f4f4f4" radius="50.0" stroke="#e0e0e0" strokeType="INSIDE" />
                                        <Label style="-fx-font-size: 40px;" text="👤" />
                                    </children>
                                </StackPane>
                                <Label fx:id="fullNameLabel" styleClass="title-label" text="User Name">
                                    <font>
                                        <Font name="Yu Gothic Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label fx:id="userRoleLabel" style="-fx-text-fill: #888888; -fx-font-weight: bold;" text="PARTNER" />
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10;">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;" text="FIRST NAME" />
                                        <Label style="-fx-font-size: 15px; -fx-text-fill: #888888;" fx:id="nameLabel" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;" text="LAST NAME" />
                                        <Label style="-fx-font-size: 15px; -fx-text-fill: #888888;" fx:id="surnameLabel" />
                                    </children>
                                </VBox>

                                <VBox spacing="2.0">
                                    <children>
                                        <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;" text="EMAIL ADDRESS" />
                                        <Label style="-fx-font-size: 15px; -fx-text-fill: #888888;" fx:id="emailLabel"/>
                                    </children>
                                </VBox>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                            </padding>
                        </VBox>

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="250.0" styleClass="primary-button" text="Change Password" onAction="#handleChangePassword"/>
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>

                        </HBox>

                    </children>
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
