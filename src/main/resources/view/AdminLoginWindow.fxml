<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane styleClass="background-pane" stylesheets="@Styles.css" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox styleClass="form-container" alignment="CENTER" layoutX="169.0" prefHeight="400.0" prefWidth="261.0">
         <children>
            <Label styleClass="title-label" text="Admin Pass" textAlignment="CENTER">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label styleClass="input-label" prefHeight="18.0" prefWidth="264.0" text="Enter de admin's password:">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <PasswordField styleClass="password-field" fx:id="adminPasswordField" />
            <Button styleClass="primary-button" id="adminLoginButton" mnemonicParsing="false" onAction="#handleAdminLogin" text="Enter">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
            <Label fx:id="statusLabel">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
         </children>
      </VBox>
      <Button styleClass="primary-button-small" fx:id="goBackButton" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleGoBack" text="&lt;--" />
   </children>
</AnchorPane>
