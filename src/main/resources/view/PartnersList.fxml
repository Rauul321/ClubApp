<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="background-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="20.0" style="-fx-background-color: rgba(255,255,255,0.03);">
                    <children>
                        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="title-label" style="-fx-font-size: 26px;" text="Club Members" />
                                <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 13px;" text="Directory of all registered partners" />
                            </children>
                        </VBox>

                        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="200.0" promptText="Search by name..." styleClass="input-field" />

                        <Button fx:id="addPartnerButton" mnemonicParsing="false" onAction="#handleAddPartner" prefHeight="40.0" prefWidth="160.0" styleClass="primary-button" text="+ Add New Partner" />
                    </children>
                    <padding>
                        <Insets left="30.0" right="30.0" bottom="10.0" top="10.0"/>
                    </padding>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="memberContainer" spacing="12.0">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>
    </children>
</AnchorPane>
